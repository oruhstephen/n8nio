# 1. Use the official n8n task runner as the base
FROM n8nio/runners:latest

# 2. Switch to root to install system dependencies
USER root
WORKDIR /opt/runners/task-runner-python

# 3. Use 'apk' (Alpine's package manager) to install Python and the C-build tools
# (Note: apt-get has been completely removed)
RUN apk add --no-cache python3 py3-pip python3-dev build-base gcc g++ musl-dev

# 4. Create a virtual environment
RUN python3 -m venv /opt/venv

# 5. Use the virtual environment to install your heavy data pipeline packages
RUN /opt/venv/bin/pip install --no-cache-dir \
    websockets pandas numpy requests finnhub-python polars \
    scipy matplotlib seaborn plotly streamlit scikit-learn \
    statsmodels xgboost

# 6. Make the virtual environment the default for the container
ENV PATH="/opt/venv/bin:$PATH"

# 7. Switch back to the default non-root user for security
USER node
